     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:dcterms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="http://purl.obolibrary.org/obo/mma.owl">
        <dcterms:description>An ontology for mouse muscle and skeletal anatomy structures</dcterms:description>
        <dcterms:license rdf:resource="https://creativecommons.org/licenses/unspecified"/>
        <dcterms:title>Mouse Muscle Atlas</dcterms:title>
    </owl:Ontology>
    


